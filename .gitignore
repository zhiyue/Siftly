# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example, ignore actual secrets
.env
.env.local
.env.*.local
.env.cloudflare

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated prisma client
/app/generated/prisma

# Database files — never commit these (contain your private bookmarks)
prisma/dev.db
prisma/dev.db-journal
dev.db
dev.db-journal
*.db
*.db-journal

# OS
.DS_Store
Thumbs.db

# Promo video tool (local only)
promo-video/

# Claude Code local settings
.claude/

# Editor
.idea/
*.swp
*.swo
*~
