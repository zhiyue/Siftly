{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "siftly",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "siftly-db",
      "database_id": "<YOUR_D1_DATABASE_ID>"
    }
  ],

  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "siftly-media"
    }
  ],

  // Durable Objects disabled — OpenNext doesn't support exporting custom DOs.
  // Pipeline state uses in-process globalThis via PipelineStateManager.
  // Re-enable when OpenNext adds DO export support.
  // "durable_objects": {
  //   "bindings": [{ "name": "PIPELINE_DO", "class_name": "PipelineDO" }]
  // },

  "vars": {
    "ANTHROPIC_BASE_URL": "",
    "OPENAI_BASE_URL": ""
  }
}
